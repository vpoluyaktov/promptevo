# ─── LLM Provider ────────────────────────────────────────────────────────────
# Choose one: openrouter | anthropic | openai  (default: openrouter)
LLM_PROVIDER=openrouter

# Set the key for your chosen provider (leave the others blank or commented out):

# OpenRouter — access any model through one key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic — direct Claude access (https://console.anthropic.com/keys)
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI — direct GPT access (https://platform.openai.com/api-keys)
# OPENAI_API_KEY=sk-your-key-here

# ─── Optional overrides (defaults shown) ─────────────────────────────────────
PORT=8080
DB_PATH=/data/promptevo.db
